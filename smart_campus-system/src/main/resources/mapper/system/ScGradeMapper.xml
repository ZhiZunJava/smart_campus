<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScGradeMapper">
    <resultMap type="ScGrade" id="ScGradeResult">
        <id property="gradeId" column="grade_id"/>
        <result property="gradeName" column="grade_name"/>
        <result property="schoolYear" column="school_year"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>
    <sql id="selectScGradeVo">
        select grade_id, grade_name, school_year, status, create_by, create_time, update_by, update_time, remark from sc_grade
    </sql>
    <select id="selectScGradeByGradeId" parameterType="Long" resultMap="ScGradeResult">
        <include refid="selectScGradeVo"/> where grade_id = #{gradeId}
    </select>
    <select id="selectScGradeList" parameterType="ScGrade" resultMap="ScGradeResult">
        <include refid="selectScGradeVo"/>
        <where>
            <if test="gradeName != null and gradeName != ''">and grade_name like concat('%', #{gradeName}, '%')</if>
            <if test="schoolYear != null and schoolYear != ''">and school_year = #{schoolYear}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by grade_id desc
    </select>
    <insert id="insertScGrade" parameterType="ScGrade" useGeneratedKeys="true" keyProperty="gradeId">
        insert into sc_grade(grade_name, school_year, status, create_by, create_time, remark)
        values(#{gradeName}, #{schoolYear}, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>
    <update id="updateScGrade" parameterType="ScGrade">
        update sc_grade
        <set>
            <if test="gradeName != null">grade_name = #{gradeName},</if>
            <if test="schoolYear != null">school_year = #{schoolYear},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where grade_id = #{gradeId}
    </update>
    <delete id="deleteScGradeByGradeId" parameterType="Long">delete from sc_grade where grade_id = #{gradeId}</delete>
    <delete id="deleteScGradeByGradeIds" parameterType="Long">delete from sc_grade where grade_id in <foreach item="gradeId" collection="array" open="(" separator="," close=")">#{gradeId}</foreach></delete>
</mapper>
