<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScExamRecordMapper">
  <resultMap type="ScExamRecord" id="ScExamRecordResult"><id property="recordId" column="record_id"/><result property="paperId" column="paper_id"/><result property="userId" column="user_id"/><result property="startTime" column="start_time"/><result property="submitTime" column="submit_time"/><result property="score" column="score"/><result property="correctRate" column="correct_rate"/><result property="examStatus" column="exam_status"/><result property="cheatFlag" column="cheat_flag"/><result property="analysisJson" column="analysis_json"/></resultMap>
  <sql id="selectScExamRecordVo">select record_id, paper_id, user_id, start_time, submit_time, score, correct_rate, exam_status, cheat_flag, analysis_json from sc_exam_record</sql>
  <select id="selectScExamRecordByRecordId" parameterType="Long" resultMap="ScExamRecordResult"><include refid="selectScExamRecordVo"/> where record_id = #{recordId}</select>
  <select id="selectScExamRecordList" parameterType="ScExamRecord" resultMap="ScExamRecordResult"><include refid="selectScExamRecordVo"/><where><if test="paperId != null">and paper_id = #{paperId}</if><if test="userId != null">and user_id = #{userId}</if><if test="examStatus != null and examStatus != ''">and exam_status = #{examStatus}</if></where> order by record_id desc</select>
  <insert id="insertScExamRecord" parameterType="ScExamRecord" useGeneratedKeys="true" keyProperty="recordId">insert into sc_exam_record(paper_id, user_id, start_time, submit_time, score, correct_rate, exam_status, cheat_flag, analysis_json) values(#{paperId}, #{userId}, #{startTime}, #{submitTime}, #{score}, #{correctRate}, #{examStatus}, #{cheatFlag}, #{analysisJson})</insert>
  <update id="updateScExamRecord" parameterType="ScExamRecord">update sc_exam_record <set><if test="paperId != null">paper_id = #{paperId},</if><if test="userId != null">user_id = #{userId},</if><if test="startTime != null">start_time = #{startTime},</if><if test="submitTime != null">submit_time = #{submitTime},</if><if test="score != null">score = #{score},</if><if test="correctRate != null">correct_rate = #{correctRate},</if><if test="examStatus != null">exam_status = #{examStatus},</if><if test="cheatFlag != null">cheat_flag = #{cheatFlag},</if><if test="analysisJson != null">analysis_json = #{analysisJson},</if></set> where record_id = #{recordId}</update>
  <delete id="deleteScExamRecordByRecordId" parameterType="Long">delete from sc_exam_record where record_id = #{recordId}</delete>
  <delete id="deleteScExamRecordByRecordIds" parameterType="Long">delete from sc_exam_record where record_id in <foreach item="recordId" collection="array" open="(" separator="," close=")">#{recordId}</foreach></delete>
</mapper>
