<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScResourceNodeMapper">
  <resultMap type="ScResourceNode" id="ScResourceNodeResult">
    <id property="nodeId" column="node_id" />
    <result property="courseId" column="course_id" />
    <result property="parentId" column="parent_id" />
    <result property="nodeName" column="node_name" />
    <result property="sortNo" column="sort_no" />
    <result property="expandDefault" column="expand_default" />
    <result property="status" column="status" />
    <result property="createBy" column="create_by" />
    <result property="createTime" column="create_time" />
    <result property="updateBy" column="update_by" />
    <result property="updateTime" column="update_time" />
    <result property="remark" column="remark" />
  </resultMap>

  <sql id="selectScResourceNodeVo">
    select node_id, course_id, parent_id, node_name, sort_no, expand_default, status,
           create_by, create_time, update_by, update_time, remark
    from sc_resource_node
  </sql>

  <select id="selectScResourceNodeByNodeId" parameterType="Long" resultMap="ScResourceNodeResult">
    <include refid="selectScResourceNodeVo" />
    where node_id = #{nodeId}
  </select>

  <select id="selectScResourceNodeList" parameterType="ScResourceNode" resultMap="ScResourceNodeResult">
    <include refid="selectScResourceNodeVo" />
    <where>
      <if test="courseId != null">and course_id = #{courseId}</if>
      <if test="parentId != null">and parent_id = #{parentId}</if>
      <if test="nodeName != null and nodeName != ''">and node_name like concat('%', #{nodeName}, '%')</if>
      <if test="status != null and status != ''">and status = #{status}</if>
    </where>
    order by sort_no asc, node_id asc
  </select>

  <insert id="insertScResourceNode" parameterType="ScResourceNode" useGeneratedKeys="true" keyProperty="nodeId">
    insert into sc_resource_node(course_id, parent_id, node_name, sort_no, expand_default, status, create_by, create_time, remark)
    values(#{courseId}, #{parentId}, #{nodeName}, #{sortNo}, #{expandDefault}, #{status}, #{createBy}, sysdate(), #{remark})
  </insert>

  <update id="updateScResourceNode" parameterType="ScResourceNode">
    update sc_resource_node
    <set>
      <if test="courseId != null">course_id = #{courseId},</if>
      <if test="parentId != null">parent_id = #{parentId},</if>
      <if test="nodeName != null">node_name = #{nodeName},</if>
      <if test="sortNo != null">sort_no = #{sortNo},</if>
      <if test="expandDefault != null">expand_default = #{expandDefault},</if>
      <if test="status != null">status = #{status},</if>
      <if test="updateBy != null">update_by = #{updateBy},</if>
      <if test="remark != null">remark = #{remark},</if>
      update_time = sysdate()
    </set>
    where node_id = #{nodeId}
  </update>

  <delete id="deleteScResourceNodeByNodeId" parameterType="Long">
    delete from sc_resource_node where node_id = #{nodeId}
  </delete>

  <delete id="deleteScResourceNodeByNodeIds" parameterType="Long">
    delete from sc_resource_node where node_id in
    <foreach item="nodeId" collection="array" open="(" separator="," close=")">
      #{nodeId}
    </foreach>
  </delete>
</mapper>
