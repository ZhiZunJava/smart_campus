<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScParentStudentRelMapper">

    <resultMap type="ScParentStudentRel" id="ScParentStudentRelResult">
        <id property="id" column="id"/>
        <result property="parentUserId" column="parent_user_id"/>
        <result property="studentUserId" column="student_user_id"/>
        <result property="relationType" column="relation_type"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectScParentStudentRelVo">
        select id, parent_user_id, student_user_id, relation_type, status,
               create_by, create_time, update_by, update_time, remark
        from sc_parent_student_rel
    </sql>

    <select id="selectScParentStudentRelById" parameterType="Long" resultMap="ScParentStudentRelResult">
        <include refid="selectScParentStudentRelVo"/>
        where id = #{id}
    </select>

    <select id="selectScParentStudentRelList" parameterType="ScParentStudentRel" resultMap="ScParentStudentRelResult">
        <include refid="selectScParentStudentRelVo"/>
        <where>
            <if test="parentUserId != null">and parent_user_id = #{parentUserId}</if>
            <if test="studentUserId != null">and student_user_id = #{studentUserId}</if>
            <if test="relationType != null and relationType != ''">and relation_type = #{relationType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>

    <insert id="insertScParentStudentRel" parameterType="ScParentStudentRel" useGeneratedKeys="true" keyProperty="id">
        insert into sc_parent_student_rel
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentUserId != null">parent_user_id,</if>
            <if test="studentUserId != null">student_user_id,</if>
            <if test="relationType != null">relation_type,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentUserId != null">#{parentUserId},</if>
            <if test="studentUserId != null">#{studentUserId},</if>
            <if test="relationType != null">#{relationType},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateScParentStudentRel" parameterType="ScParentStudentRel">
        update sc_parent_student_rel
        <set>
            <if test="parentUserId != null">parent_user_id = #{parentUserId},</if>
            <if test="studentUserId != null">student_user_id = #{studentUserId},</if>
            <if test="relationType != null">relation_type = #{relationType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteScParentStudentRelById" parameterType="Long">
        delete from sc_parent_student_rel where id = #{id}
    </delete>

    <delete id="deleteScParentStudentRelByIds" parameterType="Long">
        delete from sc_parent_student_rel where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
