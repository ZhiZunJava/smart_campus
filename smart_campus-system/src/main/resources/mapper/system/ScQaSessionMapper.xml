<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScQaSessionMapper">
  <resultMap type="ScQaSession" id="ScQaSessionResult">
    <id property="sessionId" column="session_id"/>
    <result property="userId" column="user_id"/>
    <result property="courseId" column="course_id"/>
    <result property="sessionTitle" column="session_title"/>
    <result property="sourceType" column="source_type"/>
    <result property="status" column="status"/>
    <result property="createTime" column="create_time"/>
    <result property="updateTime" column="update_time"/>
  </resultMap>
  <sql id="selectScQaSessionVo">select session_id, user_id, course_id, session_title, source_type, status, create_time, update_time from sc_qa_session</sql>
  <select id="selectScQaSessionBySessionId" parameterType="Long" resultMap="ScQaSessionResult"><include refid="selectScQaSessionVo"/> where session_id = #{sessionId}</select>
  <select id="selectScQaSessionList" parameterType="ScQaSession" resultMap="ScQaSessionResult"><include refid="selectScQaSessionVo"/><where><if test="userId != null">and user_id = #{userId}</if><if test="courseId != null">and course_id = #{courseId}</if><if test="sourceType != null and sourceType != ''">and source_type = #{sourceType}</if><if test="status != null and status != ''">and status = #{status}</if></where> order by session_id desc</select>
  <insert id="insertScQaSession" parameterType="ScQaSession" useGeneratedKeys="true" keyProperty="sessionId">insert into sc_qa_session(user_id, course_id, session_title, source_type, status, create_time, update_time) values(#{userId}, #{courseId}, #{sessionTitle}, #{sourceType}, #{status}, sysdate(), sysdate())</insert>
  <update id="updateScQaSession" parameterType="ScQaSession">update sc_qa_session <set><if test="userId != null">user_id = #{userId},</if><if test="courseId != null">course_id = #{courseId},</if><if test="sessionTitle != null">session_title = #{sessionTitle},</if><if test="sourceType != null">source_type = #{sourceType},</if><if test="status != null">status = #{status},</if>update_time = sysdate()</set> where session_id = #{sessionId}</update>
  <delete id="deleteScQaSessionBySessionId" parameterType="Long">delete from sc_qa_session where session_id = #{sessionId}</delete>
  <delete id="deleteScQaSessionBySessionIds" parameterType="Long">delete from sc_qa_session where session_id in <foreach item="sessionId" collection="array" open="(" separator="," close=")">#{sessionId}</foreach></delete>
</mapper>
