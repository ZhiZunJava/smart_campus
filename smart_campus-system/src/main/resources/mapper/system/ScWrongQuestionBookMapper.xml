  <insert id="insertScWrongQuestionBook" parameterType="ScWrongQuestionBook" useGeneratedKeys="true" keyProperty="id">insert into sc_wrong_question_book(user_id, question_id, course_id, wrong_count, last_wrong_time, mastery_status) values(#{userId}, #{questionId}, #{courseId}, #{wrongCount}, #{lastWrongTime}, #{masteryStatus})</insert>
  <update id="updateScWrongQuestionBook" parameterType="ScWrongQuestionBook">update sc_wrong_question_book <set><if test="userId != null">user_id = #{userId},</if><if test="questionId != null">question_id = #{questionId},</if><if test="courseId != null">course_id = #{courseId},</if><if test="wrongCount != null">wrong_count = #{wrongCount},</if><if test="lastWrongTime != null">last_wrong_time = #{lastWrongTime},</if><if test="masteryStatus != null">mastery_status = #{masteryStatus},</if></set> where id = #{id}</update>
  <delete id="deleteScWrongQuestionBookById" parameterType="Long">delete from sc_wrong_question_book where id = #{id}</delete>
  <delete id="deleteScWrongQuestionBookByIds" parameterType="Long">delete from sc_wrong_question_book where id in <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
