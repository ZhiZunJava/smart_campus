<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScWrongQuestionBookMapper">
  <resultMap type="ScWrongQuestionBook" id="ScWrongQuestionBookResult"><id property="id" column="id"/><result property="userId" column="user_id"/><result property="questionId" column="question_id"/><result property="courseId" column="course_id"/><result property="wrongCount" column="wrong_count"/><result property="lastWrongTime" column="last_wrong_time"/><result property="masteryStatus" column="mastery_status"/></resultMap>
  <sql id="selectScWrongQuestionBookVo">select id, user_id, question_id, course_id, wrong_count, last_wrong_time, mastery_status from sc_wrong_question_book</sql>
  <select id="selectScWrongQuestionBookById" parameterType="Long" resultMap="ScWrongQuestionBookResult"><include refid="selectScWrongQuestionBookVo"/> where id = #{id}</select>
