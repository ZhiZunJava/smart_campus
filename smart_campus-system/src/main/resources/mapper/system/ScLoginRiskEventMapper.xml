    <sql id="selectScLoginRiskEventVo"> select id, user_id, login_ip, login_location,
        device_fingerprint, device_type, browser, os, login_time, risk_type, risk_score, risk_level,
        dispose_action, dispose_status, evidence_json, remark from sc_login_risk_event </sql>

    <select id="selectScLoginRiskEventById" parameterType="Long" resultMap="ScLoginRiskEventResult">
        <include refid="selectScLoginRiskEventVo" /> where id = #{id} </select>

    <select id="selectScLoginRiskEventList" parameterType="ScLoginRiskEvent"
        resultMap="ScLoginRiskEventResult">
        <include refid="selectScLoginRiskEventVo" />
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if
                test="loginIp != null and loginIp != ''">and login_ip like concat('%', #{loginIp},
        '%')</if>
            <if test="riskType != null and riskType != ''">and risk_type = #{riskType}</if>
            <if
                test="riskLevel != null and riskLevel != ''">and risk_level = #{riskLevel}</if>
            <if
                test="disposeStatus != null and disposeStatus != ''">and dispose_status =
        #{disposeStatus}</if>
        </where> order by id desc </select>

