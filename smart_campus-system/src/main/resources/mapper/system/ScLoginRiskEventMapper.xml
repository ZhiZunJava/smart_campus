            <if test="riskLevel != null">risk_level,</if>
            <if
                test="disposeAction != null">dispose_action,</if>
            <if test="disposeStatus != null">
        dispose_status,</if>
            <if test="evidenceJson != null">evidence_json,</if>
            <if
                test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")"
            suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="loginIp != null">#{loginIp},</if>
            <if
                test="loginLocation != null">#{loginLocation},</if>
            <if
                test="deviceFingerprint != null">#{deviceFingerprint},</if>
            <if
                test="deviceType != null">#{deviceType},</if>
            <if test="browser != null">#{browser},</if>
            <if
