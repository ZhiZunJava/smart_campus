            </choose>
            <if test="riskType != null">
        #{riskType},</if>
            <if test="riskScore != null">#{riskScore},</if>
            <if test="riskLevel != null">
        #{riskLevel},</if>
            <if test="disposeAction != null">#{disposeAction},</if>
            <if
