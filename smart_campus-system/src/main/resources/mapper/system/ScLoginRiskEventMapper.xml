        </set> where id = #{id} </update>

    <delete id="deleteScLoginRiskEventById" parameterType="Long"> delete from sc_login_risk_event
        where id = #{id} </delete>

    <delete id="deleteScLoginRiskEventByIds" parameterType="Long"> delete from sc_login_risk_event
