<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScLoginRiskEventMapper">

    <resultMap type="ScLoginRiskEvent" id="ScLoginRiskEventResult">
        <id property="id" column="id" />
