    <delete id="deleteScAffairTemplateByTemplateId" parameterType="Long"> delete from
        sc_affair_template where template_id = #{templateId} </delete>

    <delete id="deleteScAffairTemplateByTemplateIds" parameterType="Long"> delete from
        sc_affair_template where template_id in <foreach item="templateId" collection="array"
            open="(" separator="," close=")"> #{templateId} </foreach>
    </delete>
</mapper>