            <if
                test="formSchemaJson != null">form_schema_json = #{formSchemaJson},</if>
            <if
                test="workflowSchemaJson != null">workflow_schema_json = #{workflowSchemaJson},</if>
            <if
                test="allowAttachment != null">allow_attachment = #{allowAttachment},</if>
            <if
                test="allowRevoke != null">allow_revoke = #{allowRevoke},</if>
            <if
