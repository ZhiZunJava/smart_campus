            <if
                test="businessRulesJson != null">business_rules_json = #{businessRulesJson},</if>
            <if
                test="targetStatusCode != null">target_status_code = #{targetStatusCode},</if>
            <if
                test="targetStatusName != null">target_status_name = #{targetStatusName},</if>
            <if
