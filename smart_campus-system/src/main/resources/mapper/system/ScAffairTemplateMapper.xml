<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScAffairTemplateMapper">
    <resultMap id="ScAffairTemplateResult" type="ScAffairTemplate">
        <id property="templateId" column="template_id" />
        <result property="categoryId" column="category_id" />
        <result property="categoryCode" column="category_code" />
        <result property="categoryName" column="category_name" />
        <result property="templateCode" column="template_code" />
        <result property="templateName" column="template_name" />
        <result property="businessCode" column="business_code" />
        <result property="businessName" column="business_name" />
        <result property="audienceRoles" column="audience_roles" />
        <result property="formSchemaJson" column="form_schema_json" />
        <result property="workflowSchemaJson" column="workflow_schema_json" />
        <result property="allowAttachment" column="allow_attachment" />
        <result property="allowRevoke" column="allow_revoke" />
        <result property="applyScopeJson" column="apply_scope_json" />
        <result property="businessRulesJson" column="business_rules_json" />
        <result property="targetStatusCode" column="target_status_code" />
        <result property="targetStatusName" column="target_status_name" />
        <result property="sortOrder" column="sort_order" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectScAffairTemplateVo"> select t.template_id, t.category_id, c.category_code,
        c.category_name, t.template_code, t.template_name, t.business_code, t.business_name,
        t.audience_roles, t.form_schema_json, t.workflow_schema_json, t.allow_attachment,
        t.allow_revoke, t.apply_scope_json, t.business_rules_json, t.target_status_code,
        t.target_status_name, t.sort_order, t.status, t.create_by, t.create_time, t.update_by,
        t.update_time, t.remark from sc_affair_template t left join sc_affair_category c on
        c.category_id = t.category_id </sql>

    <select id="selectScAffairTemplateByTemplateId" parameterType="Long"
        resultMap="ScAffairTemplateResult">
        <include refid="selectScAffairTemplateVo" /> where t.template_id = #{templateId} </select>

    <select id="selectScAffairTemplateList" parameterType="ScAffairTemplate"
        resultMap="ScAffairTemplateResult">
        <include refid="selectScAffairTemplateVo" />
        <where>
            <if test="categoryId != null">and t.category_id = #{categoryId}</if>
            <if
                test="categoryCode != null and categoryCode != ''">and c.category_code =
        #{categoryCode}</if>
            <if test="templateCode != null and templateCode != ''">and
        t.template_code like concat('%', #{templateCode}, '%')</if>
            <if
                test="templateName != null and templateName != ''">and t.template_name like
        concat('%', #{templateName}, '%')</if>
            <if test="businessCode != null and businessCode != ''">and
        t.business_code = #{businessCode}</if>
            <if test="businessName != null and businessName != ''">and
        t.business_name like concat('%', #{businessName}, '%')</if>
            <if
                test="audienceRoles != null and audienceRoles != ''">and
        find_in_set(#{audienceRoles}, replace(t.audience_roles, ' ', ''))</if>
            <if
                test="status != null and status != ''">and t.status = #{status}</if>
        </where>
        order by c.sort_order asc, t.sort_order asc, t.template_id asc </select>

    <select id="selectEnabledTemplatesByRole" parameterType="String"
        resultMap="ScAffairTemplateResult">
        <include refid="selectScAffairTemplateVo" /> where t.status = '0' and c.status = '0' and
        find_in_set(#{portalRole}, replace(t.audience_roles, ' ', '')) order by c.sort_order asc,
        t.sort_order asc, t.template_id asc </select>

    <insert id="insertScAffairTemplate" parameterType="ScAffairTemplate" useGeneratedKeys="true"
        keyProperty="templateId"> insert into sc_affair_template <trim prefix="(" suffix=")"
            suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if
                test="templateCode != null and templateCode != ''">template_code,</if>
            <if
                test="templateName != null and templateName != ''">template_name,</if>
            <if
                test="businessCode != null">business_code,</if>
            <if test="businessName != null">
        business_name,</if>
            <if test="audienceRoles != null">audience_roles,</if>
            <if
                test="formSchemaJson != null">form_schema_json,</if>
            <if
                test="workflowSchemaJson != null">workflow_schema_json,</if>
            <if
                test="allowAttachment != null">allow_attachment,</if>
            <if test="allowRevoke != null">
        allow_revoke,</if>
            <if test="applyScopeJson != null">apply_scope_json,</if>
            <if
                test="businessRulesJson != null">business_rules_json,</if>
            <if
                test="targetStatusCode != null">target_status_code,</if>
            <if
                test="targetStatusName != null">target_status_name,</if>
            <if test="sortOrder != null">
        sort_order,</if>
            <if test="status != null">status,</if>
            <if
                test="createBy != null and createBy != ''">create_by,</if> create_time, <if
                test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")"
            suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if
                test="templateCode != null and templateCode != ''">#{templateCode},</if>
            <if
                test="templateName != null and templateName != ''">#{templateName},</if>
            <if
                test="businessCode != null">#{businessCode},</if>
            <if test="businessName != null">
        #{businessName},</if>
            <if test="audienceRoles != null">#{audienceRoles},</if>
            <if
                test="formSchemaJson != null">#{formSchemaJson},</if>
            <if
                test="workflowSchemaJson != null">#{workflowSchemaJson},</if>
            <if
                test="allowAttachment != null">#{allowAttachment},</if>
            <if
                test="allowRevoke != null">#{allowRevoke},</if>
            <if test="applyScopeJson != null">
        #{applyScopeJson},</if>
            <if test="businessRulesJson != null">#{businessRulesJson},</if>
            <if
                test="targetStatusCode != null">#{targetStatusCode},</if>
            <if
                test="targetStatusName != null">#{targetStatusName},</if>
            <if
                test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if
                test="createBy != null and createBy != ''">#{createBy},</if> sysdate(), <if
                test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateScAffairTemplate" parameterType="ScAffairTemplate"> update sc_affair_template <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if
                test="templateCode != null and templateCode != ''">template_code = #{templateCode},</if>
            <if
                test="templateName != null and templateName != ''">template_name = #{templateName},</if>
            <if
                test="businessCode != null">business_code = #{businessCode},</if>
            <if
                test="businessName != null">business_name = #{businessName},</if>
            <if
