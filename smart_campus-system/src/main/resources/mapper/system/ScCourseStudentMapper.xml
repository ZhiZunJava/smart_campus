<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScCourseStudentMapper">
  <resultMap type="ScCourseStudent" id="ScCourseStudentResult">
    <id property="id" column="id" />
    <result property="courseId" column="course_id" />
    <result property="courseName" column="course_name" />
    <result property="studentUserId" column="student_user_id" />
    <result property="studentName" column="student_name" />
    <result property="studentNo" column="student_no" />
    <result property="classId" column="class_id" />
    <result property="className" column="class_name" />
    <result property="joinTime" column="join_time" />
    <result property="status" column="status" />
    <result property="remark" column="remark" />
  </resultMap>
  <sql id="selectScCourseStudentVo"> select s.id, s.course_id, c.course_name, s.student_user_id,
    coalesce(p.real_name, u.nick_name, u.user_name) as student_name, p.student_no, s.class_id,
    cls.class_name, s.join_time, s.status, s.remark from sc_course_student s left join sc_course c
    on c.course_id = s.course_id left join sc_user_profile p on p.user_id = s.student_user_id left
    join sys_user u on u.user_id = s.student_user_id left join sc_class cls on cls.class_id =
    s.class_id </sql>
  <select id="selectScCourseStudentById" parameterType="Long" resultMap="ScCourseStudentResult"><include
      refid="selectScCourseStudentVo" /> where id = #{id}</select>
  <select id="selectScCourseStudentList" parameterType="ScCourseStudent"
    resultMap="ScCourseStudentResult">
    <include refid="selectScCourseStudentVo" />
    <where>
      <if test="courseId != null">and s.course_id = #{courseId}</if>
      <if test="studentUserId != null">and
    s.student_user_id = #{studentUserId}</if>
      <if test="classId != null">and s.class_id = #{classId}</if>
      <if
        test="status != null and status != ''">and s.status = #{status}</if>
    </where> order by
    s.id desc </select>
  <select id="selectDuplicateScCourseStudent" parameterType="ScCourseStudent"
    resultMap="ScCourseStudentResult">
    <include refid="selectScCourseStudentVo" /> where s.course_id = #{courseId} and
    s.student_user_id = #{studentUserId} <if test="id != null"> and s.id != #{id} </if> limit 1 </select>
  <insert id="insertScCourseStudent" parameterType="ScCourseStudent" useGeneratedKeys="true"
    keyProperty="id">insert into sc_course_student(course_id, student_user_id, class_id, join_time,
    status, remark) values(#{courseId}, #{studentUserId}, #{classId}, #{joinTime}, #{status},
    #{remark})</insert>
  <update id="updateScCourseStudent" parameterType="ScCourseStudent">update sc_course_student <set><if
        test="courseId != null">course_id = #{courseId},</if><if test="studentUserId != null">student_user_id
    = #{studentUserId},</if><if test="classId != null">class_id = #{classId},</if><if
        test="joinTime != null">join_time = #{joinTime},</if><if test="status != null">status =
    #{status},</if><if test="remark != null">remark = #{remark},</if></set> where id = #{id}</update>
  <delete id="deleteScCourseStudentById" parameterType="Long">delete from sc_course_student where id
    = #{id}</delete>
  <delete id="deleteScCourseStudentByIds" parameterType="Long">delete from sc_course_student where
    id in <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>