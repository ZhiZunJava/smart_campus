    <sql id="selectScUserProfileVo">
        select profile_id, user_id, user_type, student_no, teacher_no,
        real_name, former_name, gender, nation, birth_date, political_status, native_place, id_type, id_number,
        grade_id, class_id, advisor_user_id,
        major, cultivation_type, education_level, schooling_length,
        admission_year, admission_type, exam_number, admission_ticket_no, admission_score,
        admission_batch, source_region, graduate_school,
        learning_goal, interest_tags, learning_style, avatar_url,
        expected_graduation_date, actual_graduation_date, diploma_no, completion_type, graduation_destination, graduation_remark,
        degree_type, degree_award_date, degree_cert_no, thesis_title, degree_remark,
        contact_address, home_address, emergency_contact, emergency_phone, household_address, bank_card_no,
        status, student_status_code, student_status_name, student_status_update_time,
        create_by, create_time, update_by, update_time, remark
        from sc_user_profile
    </sql>

    <select id="selectScUserProfileByProfileId" parameterType="Long" resultMap="ScUserProfileResult">
        <include refid="selectScUserProfileVo" /> where profile_id = #{profileId}
    </select>

    <select id="selectScUserProfileByUserId" parameterType="Long" resultMap="ScUserProfileResult">
