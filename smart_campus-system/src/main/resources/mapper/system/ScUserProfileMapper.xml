    </select>

    <select id="selectScUserProfileList" parameterType="ScUserProfile" resultMap="ScUserProfileResult">
        <include refid="selectScUserProfileVo" />
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="userType != null and userType != ''">and user_type = #{userType}</if>
            <if test="studentNo != null and studentNo != ''">and student_no like concat('%', #{studentNo}, '%')</if>
            <if test="teacherNo != null and teacherNo != ''">and teacher_no like concat('%', #{teacherNo}, '%')</if>
            <if test="realName != null and realName != ''">and real_name like concat('%', #{realName}, '%')</if>
            <if test="gradeId != null">and grade_id = #{gradeId}</if>
            <if test="classId != null">and class_id = #{classId}</if>
            <if test="advisorUserId != null">and advisor_user_id = #{advisorUserId}</if>
            <if test="nation != null and nation != ''">and nation = #{nation}</if>
            <if test="politicalStatus != null and politicalStatus != ''">and political_status = #{politicalStatus}</if>
            <if test="major != null and major != ''">and major like concat('%', #{major}, '%')</if>
            <if test="educationLevel != null and educationLevel != ''">and education_level = #{educationLevel}</if>
            <if test="admissionYear != null">and admission_year = #{admissionYear}</if>
            <if test="sourceRegion != null and sourceRegion != ''">and source_region like concat('%', #{sourceRegion}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by profile_id desc
    </select>

