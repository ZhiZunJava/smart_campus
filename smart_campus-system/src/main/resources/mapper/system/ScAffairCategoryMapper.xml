<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.system.mapper.ScAffairCategoryMapper">
    <resultMap id="ScAffairCategoryResult" type="ScAffairCategory">
        <id property="categoryId" column="category_id" />
        <result property="categoryCode" column="category_code" />
        <result property="categoryName" column="category_name" />
        <result property="serviceGroup" column="service_group" />
        <result property="icon" column="icon" />
        <result property="sortOrder" column="sort_order" />
        <result property="targetRoleScope" column="target_role_scope" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectScAffairCategoryVo">
        select category_id, category_code, category_name, service_group, icon, sort_order,
               target_role_scope, status, create_by, create_time, update_by, update_time, remark
        from sc_affair_category
    </sql>

    <select id="selectScAffairCategoryByCategoryId" parameterType="Long" resultMap="ScAffairCategoryResult">
        <include refid="selectScAffairCategoryVo" />
        where category_id = #{categoryId}
    </select>

    <select id="selectScAffairCategoryByCategoryCode" parameterType="String" resultMap="ScAffairCategoryResult">
        <include refid="selectScAffairCategoryVo" />
        where category_code = #{categoryCode} limit 1
    </select>

    <select id="selectScAffairCategoryList" parameterType="ScAffairCategory" resultMap="ScAffairCategoryResult">
        <include refid="selectScAffairCategoryVo" />
        <where>
            <if test="categoryCode != null and categoryCode != ''">and category_code like concat('%', #{categoryCode}, '%')</if>
            <if test="categoryName != null and categoryName != ''">and category_name like concat('%', #{categoryName}, '%')</if>
            <if test="serviceGroup != null and serviceGroup != ''">and service_group = #{serviceGroup}</if>
            <if test="targetRoleScope != null and targetRoleScope != ''">and target_role_scope like concat('%', #{targetRoleScope}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by sort_order asc, category_id asc
    </select>

    <insert id="insertScAffairCategory" parameterType="ScAffairCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into sc_affair_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="serviceGroup != null">service_group,</if>
            <if test="icon != null">icon,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="targetRoleScope != null">target_role_scope,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="serviceGroup != null">#{serviceGroup},</if>
            <if test="icon != null">#{icon},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="targetRoleScope != null">#{targetRoleScope},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateScAffairCategory" parameterType="ScAffairCategory">
        update sc_affair_category
        <set>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="serviceGroup != null">service_group = #{serviceGroup},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="targetRoleScope != null">target_role_scope = #{targetRoleScope},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteScAffairCategoryByCategoryId" parameterType="Long">
        delete from sc_affair_category where category_id = #{categoryId}
    </delete>

    <delete id="deleteScAffairCategoryByCategoryIds" parameterType="Long">
        delete from sc_affair_category where category_id in
        <foreach item="categoryId" collection="array" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>
</mapper>
